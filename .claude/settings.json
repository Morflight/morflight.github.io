      "Bash(rm -rf *)",
      "Bash(rm -r /*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown -R *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(killall *)",
      "Bash(kill -9 *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(* | bash*)",
      "Bash(* | sh*)",
      "Bash(curl * | *)",
      "Bash(wget * | *)"
